      90% calc(100% - 20px),
      90% 100%,
      70% 100%,
      70% calc(100% - 20px),
      0% calc(100% - 20px)
    );
  }

  /* Fifth card - notch top-right, tab bottom-left */
  .bento-puzzle-bl {
    grid-column: span 1;
    grid-row: span 1;
    min-height: 180px;
    margin: 0;
    padding: 0;
    border-radius: 24px;
    margin-top: -20px;
    margin-bottom: -20px;
    padding-top: 20px;
    clip-path: polygon(
      0% 20px,
      70% 20px,
      70% 0,
      90% 0,
      90% 20px,
      100% 20px,
      100% calc(100% - 20px),
      30% calc(100% - 20px),
      30% 100%,
      10% 100%,
      10% calc(100% - 20px),
      0% calc(100% - 20px)
    );
  }

  /* Sixth card - notch top-left, tab bottom-right */
  .bento-puzzle-br {
    grid-column: span 1;
    grid-row: span 1;
    min-height: 180px;
    margin: 0;
    padding: 0;
    border-radius: 24px;
    margin-top: -20px;
    margin-bottom: -20px;
    padding-top: 20px;
    clip-path: polygon(
      0% 20px,
