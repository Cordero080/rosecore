      90% calc(100% - 20px),
      90% 100%,
      70% 100%,
      70% calc(100% - 20px),
      0% calc(100% - 20px)
    );
  }

  /* Center card - Pneuma - notch top-right, tab bottom-left */
  .bento-center {
    grid-column: span 1;
    grid-row: span 1;
    min-height: 220px;
    margin: 0;
    padding: 0;
    border-radius: 24px;
    margin-top: -20px;
    margin-bottom: -20px;
    padding-top: 20px;
    clip-path: polygon(
      0% 20px,
      70% 20px,
      70% 0,
      90% 0,
      90% 20px,
      100% 20px,
      100% calc(100% - 20px),
      30% calc(100% - 20px),
      30% 100%,
      10% 100%,
      10% calc(100% - 20px),
      0% calc(100% - 20px)
    );
  }

  /* Bookshelf card - notch top-left, no tab at bottom (last card) */
  .bento-bookshelf {
    grid-column: span 1;
    grid-row: span 1;
    min-height: 220px;
    margin: 0;
    padding: 0;
    border-radius: 24px;
    margin-top: -20px;
    padding-top: 20px;
    clip-path: polygon(
